<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="@dimen/spacing_lg">

    <ImageView
        android:id="@+id/emptyIcon"
        android:layout_width="@dimen/empty_state_icon_size"
        android:layout_height="@dimen/empty_state_icon_size"
        android:alpha="@dimen/empty_state_icon_alpha"
        android:contentDescription="@null"
        android:importantForAccessibility="no"
        android:visibility="gone"
        app:tint="?android:attr/textColorSecondary"
        tools:src="@drawable/ic_tab_config"
        tools:visibility="visible" />

    <TextView
        android:id="@+id/emptyMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_md"
        android:gravity="center"
        android:text="@string/managed_empty_message"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="13sp"
        tools:text="No managed apps yet" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/emptyAction"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_md"
        android:text="@string/add_managed_app"
        tools:visibility="visible" />

</LinearLayout>
