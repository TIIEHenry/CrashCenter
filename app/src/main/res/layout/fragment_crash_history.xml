<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <TextView
        android:id="@+id/eventCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/filter_horizontal_padding"
        android:paddingTop="@dimen/filter_row_padding_vertical"
        android:paddingBottom="@dimen/spacing_xs"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="13sp"
        android:visibility="gone"
        tools:text="3 crash records"
        tools:visibility="visible" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:visibility="gone"
            tools:visibility="visible" />

        <include
            android:id="@+id/loadingPanel"
            layout="@layout/view_loading_state"
            android:visibility="gone" />

        <include
            android:id="@+id/emptyState"
            layout="@layout/view_empty_state"
            android:visibility="gone" />

    </FrameLayout>

</LinearLayout>
