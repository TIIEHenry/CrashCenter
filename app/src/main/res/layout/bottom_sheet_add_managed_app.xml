<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingBottom="@dimen/spacing_md">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/sheet_drag_handle_hit_height"
        android:importantForAccessibility="noHideDescendants">

        <View
            android:id="@+id/sheetDragHandle"
            android:layout_width="@dimen/sheet_drag_handle_width"
            android:layout_height="@dimen/sheet_drag_handle_height"
            android:layout_gravity="center"
            android:background="@drawable/bg_sheet_drag_handle"
            android:importantForAccessibility="no" />

    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            style="@style/AppTheme.Toolbar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/toolbar_height"
            app:navigationIcon="@drawable/ic_close"
            app:navigationIconTint="?android:attr/textColorPrimary"
            app:title="@string/add_managed_app"
            app:titleTextAppearance="@style/TextAppearance.App.ToolbarTitle">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDone"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:minWidth="0dp"
                android:minHeight="@dimen/list_item_min_height"
                android:paddingHorizontal="@dimen/spacing_xs"
                android:paddingVertical="0dp"
                android:text="@string/add_managed_done"
                android:textAllCaps="false"
                android:textColor="?attr/colorPrimary"
                android:textSize="12sp"
                android:textStyle="bold" />

        </com.google.android.material.appbar.MaterialToolbar>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/toolbarDivider" />

    </LinearLayout>

    <include
        android:id="@+id/searchField"
        layout="@layout/view_dense_search_field"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/filter_horizontal_padding"
        android:layout_marginTop="@dimen/spacing_sm" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/spacing_sm"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerPickable"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingHorizontal="@dimen/filter_horizontal_padding"
            tools:listitem="@layout/item_pickable_app" />

        <include
            android:id="@+id/loadingPanel"
            layout="@layout/view_loading_state"
            android:visibility="gone" />

        <include
            android:id="@+id/emptyState"
            layout="@layout/view_empty_state"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            tools:visibility="visible" />

    </FrameLayout>

</LinearLayout>
