<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"

    xmlns:app="http://schemas.android.com/apk/res-auto"

    xmlns:tools="http://schemas.android.com/tools"

    android:layout_width="match_parent"

    android:layout_height="match_parent"

    android:background="@color/background"

    android:orientation="vertical">



    <LinearLayout

        android:id="@+id/toolbarHeader"

        android:layout_width="match_parent"

        android:layout_height="wrap_content"

        android:background="@color/surface"

        android:orientation="vertical">



        <com.google.android.material.appbar.MaterialToolbar

            android:id="@+id/toolbar"

            style="@style/AppTheme.Toolbar"

            android:layout_width="match_parent"

            android:layout_height="@dimen/toolbar_height"

            app:titleTextAppearance="@style/TextAppearance.App.ToolbarTitle"

            app:title="@string/app_name" />



        <View

            android:layout_width="match_parent"

            android:layout_height="1dp"

            android:background="@color/toolbarDivider" />



    </LinearLayout>



    <LinearLayout

        android:layout_width="match_parent"

        android:layout_height="wrap_content"

        android:orientation="vertical"

        android:paddingStart="@dimen/filter_horizontal_padding"

        android:paddingTop="@dimen/filter_row_padding_vertical"

        android:paddingEnd="@dimen/filter_horizontal_padding"

        android:paddingBottom="@dimen/filter_row_padding_vertical">



        <LinearLayout

            android:id="@+id/statusBanner"

            android:layout_width="match_parent"

            android:layout_height="wrap_content"

            android:background="@drawable/bg_status_inactive"

            android:clickable="true"

            android:focusable="true"

            android:foreground="?attr/selectableItemBackground"

            android:gravity="center_vertical"

            android:minHeight="@dimen/status_banner_height"

            android:orientation="horizontal"

            android:paddingHorizontal="@dimen/spacing_sm"

            android:paddingVertical="@dimen/spacing_xs">



            <ImageView

                android:id="@+id/statusIcon"

                android:layout_width="@dimen/status_icon_size"

                android:layout_height="@dimen/status_icon_size"

                android:contentDescription="@string/xposed_status_title"

                android:src="@drawable/ic_shield_off" />



            <TextView

                android:id="@+id/statusTitle"

                android:layout_width="0dp"

                android:layout_height="wrap_content"

                android:layout_marginStart="@dimen/spacing_sm"

                android:layout_weight="1"

                android:ellipsize="end"

                android:maxLines="1"

                android:text="@string/xposed_not_active"

                android:textColor="@color/statusInactiveText"

                android:textSize="13sp"

                android:textStyle="bold" />



            <TextView

                android:id="@+id/statusMessage"

                android:layout_width="wrap_content"

                android:layout_height="wrap_content"

                android:visibility="gone"

                tools:text="@string/xposed_hint" />



        </LinearLayout>



        <LinearLayout

            android:id="@+id/permissionBanner"

            android:layout_width="match_parent"

            android:layout_height="wrap_content"

            android:layout_marginTop="@dimen/filter_row_section_gap"

            android:background="@drawable/bg_status_permission"

            android:clickable="true"

            android:focusable="true"

            android:foreground="?attr/selectableItemBackground"

            android:gravity="center_vertical"

            android:minHeight="@dimen/status_banner_height"

            android:orientation="horizontal"

            android:paddingHorizontal="@dimen/spacing_sm"

            android:paddingVertical="@dimen/spacing_xs"

            android:visibility="gone"

            tools:visibility="visible">



            <ImageView

                android:id="@+id/permissionBannerIcon"

                android:layout_width="@dimen/status_icon_size"

                android:layout_height="@dimen/status_icon_size"

                android:contentDescription="@string/permission_banner_title"

                android:src="@drawable/ic_app_visibility" />



            <TextView

                android:id="@+id/permissionBannerTitle"

                android:layout_width="0dp"

                android:layout_height="wrap_content"

                android:layout_marginStart="@dimen/spacing_sm"

                android:layout_weight="1"

                android:ellipsize="end"

                android:maxLines="2"

                android:text="@string/permission_banner_title"

                android:textColor="@color/fluent_accent"

                android:textSize="12sp"

                android:textStyle="bold" />



            <com.google.android.material.button.MaterialButton

                android:id="@+id/permissionGrantButton"

                style="@style/Widget.MaterialComponents.Button.TextButton"

                android:layout_width="wrap_content"

                android:layout_height="wrap_content"

                android:minWidth="0dp"

                android:minHeight="0dp"

                android:paddingHorizontal="@dimen/spacing_xs"

                android:paddingVertical="0dp"

                android:text="@string/permission_grant_action"

                android:textAllCaps="false"

                android:textColor="@color/fluent_accent"

                android:textSize="12sp"

                android:textStyle="bold" />



        </LinearLayout>



        <HorizontalScrollView

            android:layout_width="match_parent"

            android:layout_height="wrap_content"

            android:layout_marginTop="@dimen/filter_row_section_gap"

            android:scrollbars="none">



            <com.google.android.material.chip.ChipGroup

                android:id="@+id/settingsChips"

                android:layout_width="wrap_content"

                android:layout_height="wrap_content"

                app:singleLine="true"

                app:singleSelection="false">



                <com.google.android.material.chip.Chip

                    android:id="@+id/chipScopeMode"

                    style="@style/AppTheme.Chip.Setting"

                    android:layout_width="wrap_content"

                    android:layout_height="wrap_content"

                    android:checkable="true"

                    android:text="@string/item_scope_mode_short" />



                <com.google.android.material.chip.Chip

                    android:id="@+id/chipHandleSystem"

                    style="@style/AppTheme.Chip.Setting"

                    android:layout_width="wrap_content"

                    android:layout_height="wrap_content"

                    android:checkable="true"

                    android:text="@string/item_handle_system_short" />



                <com.google.android.material.chip.Chip

                    android:id="@+id/chipShowSystem"

                    style="@style/AppTheme.Chip.Setting"

                    android:layout_width="wrap_content"

                    android:layout_height="wrap_content"

                    android:checkable="true"

                    android:text="@string/item_show_system_short" />



            </com.google.android.material.chip.ChipGroup>



        </HorizontalScrollView>



        <com.google.android.material.textfield.TextInputLayout

            android:id="@+id/searchLayout"

            style="@style/AppTheme.SearchField"

            android:layout_width="match_parent"

            android:layout_height="wrap_content"

            android:layout_marginTop="@dimen/filter_row_section_gap"

            app:endIconMode="clear_text"

            app:startIconDrawable="@drawable/ic_search">



            <com.google.android.material.textfield.TextInputEditText

                android:id="@+id/searchInput"

                style="@style/AppTheme.SearchField.EditText"

                android:layout_width="match_parent"

                android:layout_height="wrap_content"

                android:hint="@string/search_hint"

                android:imeOptions="actionSearch"

                android:inputType="text"

                android:maxLines="1"

                android:paddingVertical="@dimen/spacing_xs" />



        </com.google.android.material.textfield.TextInputLayout>



        <LinearLayout

            android:layout_width="match_parent"

            android:layout_height="wrap_content"

            android:layout_marginTop="@dimen/filter_row_section_gap"

            android:gravity="center_vertical"

            android:minHeight="@dimen/filter_row_height"

            android:orientation="horizontal">



            <HorizontalScrollView

                android:layout_width="0dp"

                android:layout_height="wrap_content"

                android:layout_weight="1"

                android:scrollbars="none">



                <com.google.android.material.chip.ChipGroup

                    android:id="@+id/filterChips"

                    android:layout_width="wrap_content"

                    android:layout_height="wrap_content"

                    app:singleLine="true"

                    app:singleSelection="true">



                    <com.google.android.material.chip.Chip

                        android:id="@+id/chipAll"

                        style="@style/AppTheme.Chip"

                        android:layout_width="wrap_content"

                        android:layout_height="wrap_content"

                        android:checked="true"

                        android:text="@string/item_all" />



                    <com.google.android.material.chip.Chip

                        android:id="@+id/chipOn"

                        style="@style/AppTheme.Chip"

                        android:layout_width="wrap_content"

                        android:layout_height="wrap_content"

                        android:text="@string/item_selected" />



                    <com.google.android.material.chip.Chip

                        android:id="@+id/chipOff"

                        style="@style/AppTheme.Chip"

                        android:layout_width="wrap_content"

                        android:layout_height="wrap_content"

                        android:text="@string/item_not_selected" />



                </com.google.android.material.chip.ChipGroup>



            </HorizontalScrollView>



            <TextView

                android:id="@+id/appCount"

                android:layout_width="wrap_content"

                android:layout_height="wrap_content"

                android:layout_marginStart="@dimen/spacing_sm"

                android:textColor="@color/textTertiary"

                android:textSize="12sp"

                tools:text="128 apps" />



        </LinearLayout>



    </LinearLayout>



    <FrameLayout

        android:layout_width="match_parent"

        android:layout_height="0dp"

        android:layout_weight="1">



        <androidx.recyclerview.widget.RecyclerView

            android:id="@+id/recyclerv"

            android:layout_width="match_parent"

            android:layout_height="match_parent"

            android:clipToPadding="false"

            android:paddingHorizontal="@dimen/filter_horizontal_padding"

            android:paddingBottom="@dimen/spacing_md"

            tools:listitem="@layout/activity_main_appitem" />



        <LinearLayout

            android:id="@+id/loadingPanel"

            android:layout_width="match_parent"

            android:layout_height="match_parent"

            android:gravity="center"

            android:orientation="vertical"

            android:padding="@dimen/spacing_lg"

            android:visibility="gone">



            <com.google.android.material.progressindicator.CircularProgressIndicator

                android:layout_width="wrap_content"

                android:layout_height="wrap_content"

                android:indeterminate="true"

                app:indicatorColor="@color/colorPrimary" />



            <TextView

                android:layout_width="wrap_content"

                android:layout_height="wrap_content"

                android:layout_marginTop="@dimen/spacing_sm"

                android:text="@string/loading_message"

                android:textColor="@color/textSecondary"

                android:textSize="13sp" />



        </LinearLayout>



        <TextView

            android:id="@+id/emptyState"

            android:layout_width="match_parent"

            android:layout_height="match_parent"

            android:gravity="center"

            android:padding="@dimen/spacing_lg"

            android:text="@string/filter_empty"

            android:textColor="@color/textSecondary"

            android:textSize="13sp"

            android:visibility="gone" />



    </FrameLayout>



</LinearLayout>

