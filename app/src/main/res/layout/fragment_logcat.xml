<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/contentContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone"
        tools:visibility="visible">

        <!-- Level filter chips -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:paddingHorizontal="@dimen/spacing_sm"
            android:scrollbars="none">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingVertical="@dimen/spacing_sm"
                app:singleSelection="false">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipFatal"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/logcat_level_fatal" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipError"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/logcat_level_error" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipWarning"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/logcat_level_warning" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipInfo"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/logcat_level_info" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipDebug"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/logcat_level_debug" />

            </com.google.android.material.chip.ChipGroup>

        </HorizontalScrollView>

        <!-- Entry count -->
        <TextView
            android:id="@+id/entryCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/spacing_lg"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:textColor="?android:attr/textColorSecondary"
            tools:text="42 entries" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="@dimen/spacing_lg" />

    </LinearLayout>

    <include
        android:id="@+id/loadingPanel"
        layout="@layout/view_loading_state"
        android:visibility="gone" />

    <include
        android:id="@+id/emptyState"
        layout="@layout/view_empty_state"
        android:visibility="gone" />

</FrameLayout>
