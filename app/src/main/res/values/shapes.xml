<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Fluent 2 corner radii: Control = 4dp, Overlay = 8dp -->

    <style name="ShapeAppearance.App.Corner.Control" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/fluent_corner_radius_control</item>
    </style>

    <style name="ShapeAppearance.App.Corner.Overlay" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/fluent_corner_radius_overlay</item>
    </style>

    <style name="ShapeAppearance.App.Corner.SheetTop" parent="">
        <item name="cornerFamilyTopLeft">rounded</item>
        <item name="cornerFamilyTopRight">rounded</item>
        <item name="cornerSizeTopLeft">@dimen/radius_mobile_sheet</item>
        <item name="cornerSizeTopRight">@dimen/radius_mobile_sheet</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>
</resources>
