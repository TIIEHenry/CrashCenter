<resources>

    <style name="AppTheme" parent="Theme.Material3.DayNight.NoActionBar">

        <!-- M3 semantic color slots (Fluent palette mapped) -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorOnPrimary">@color/colorOnPrimary</item>
        <item name="colorPrimaryContainer">@color/primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/fluent_accent</item>

        <item name="android:colorBackground">@color/background</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/textPrimary</item>
        <item name="colorSurfaceVariant">@color/surfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/textSecondary</item>
        <item name="colorOutline">@color/outline</item>
        <item name="colorOutlineVariant">@color/outlineVariant</item>
        <item name="colorError">@color/status_warning</item>

        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>

        <item name="android:textColorPrimary">@color/textPrimary</item>
        <item name="android:textColorSecondary">@color/textSecondary</item>

        <item name="colorControlNormal">?android:attr/textColorPrimary</item>

        <!-- M3 widget style overrides -->
        <item name="chipStyle">@style/AppTheme.Chip</item>
        <item name="switchStyle">@style/AppTheme.Switch</item>
        <item name="bottomNavigationStyle">@style/AppTheme.BottomNavigation</item>
        <item name="toolbarStyle">@style/AppTheme.Toolbar</item>
        <item name="textInputStyle">@style/AppTheme.SearchField</item>
        <item name="materialButtonStyle">@style/AppTheme.Button</item>
        <item name="recyclerViewStyle">@style/AppTheme.FastScrollRecyclerView</item>

        <!-- Custom attrs (Fluent semantic) -->
        <item name="statusBannerActiveBackground">@color/statusActiveBg</item>
        <item name="statusBannerInactiveBackground">@color/statusInactiveBg</item>
        <item name="statusBannerActiveTextColor">@color/statusActiveText</item>
        <item name="statusBannerInactiveTextColor">@color/statusInactiveText</item>
        <item name="dividerColor">@color/toolbarDivider</item>

    </style>



    <style name="AppTheme.Toolbar" parent="Widget.Material3.Toolbar">

        <item name="android:background">@color/surface</item>

        <item name="backgroundTint">@null</item>

        <item name="android:elevation">@dimen/toolbar_elevation</item>

        <item name="elevation">@dimen/toolbar_elevation</item>

        <item name="titleTextColor">@color/textPrimary</item>

        <item name="subtitleTextColor">@color/textSecondary</item>

        <item name="android:minHeight">@dimen/toolbar_height</item>

        <item name="actionMenuTextColor">?android:attr/textColorPrimary</item>

    </style>



    <style name="TextAppearance.App.ToolbarTitle" parent="TextAppearance.Material3.TitleMedium">

        <item name="android:textColor">@color/textPrimary</item>

        <item name="android:textSize">17sp</item>

        <item name="android:fontFamily">sans-serif-medium</item>

    </style>



    <style name="AppTheme.Chip" parent="Widget.Material3.Chip.Filter">

        <item name="chipBackgroundColor">@color/chip_background_color</item>

        <item name="chipStrokeColor">@color/chip_stroke_color</item>

        <item name="chipStrokeWidth">1dp</item>

        <item name="chipMinHeight">@dimen/chip_min_height_compact</item>

        <item name="checkedIconVisible">false</item>

        <item name="android:textColor">@color/chip_text_color</item>

        <item name="android:textSize">13sp</item>

        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.App.Corner.Control</item>

        <!-- Fluent: chips use overlay+clip press, not Material ripple -->
        <item name="rippleColor">@android:color/transparent</item>

    </style>



    <style name="AppTheme.Chip.Setting" parent="Widget.Material3.Chip.Filter">

        <item name="chipBackgroundColor">@color/chip_background_color</item>

        <item name="chipStrokeColor">@color/chip_stroke_color</item>

        <item name="chipStrokeWidth">1dp</item>

        <item name="chipMinHeight">@dimen/chip_min_height_compact</item>

        <item name="checkedIconVisible">false</item>

        <item name="android:textColor">@color/chip_text_color</item>

        <item name="android:textSize">13sp</item>

        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.App.Corner.Control</item>

        <!-- Fluent: chips use overlay+clip press, not Material ripple -->
        <item name="rippleColor">@android:color/transparent</item>

    </style>



    <style name="AppTheme.SearchField" parent="Widget.Material3.TextInputLayout.OutlinedBox.Dense">

        <item name="boxStrokeColor">@color/outline</item>

        <item name="hintTextColor">@color/textSecondary</item>

        <item name="startIconTint">?android:attr/textColorSecondary</item>

        <item name="android:textColorHint">@color/textSecondary</item>

        <item name="boxCornerRadiusTopStart">@dimen/radius_mobile_control</item>

        <item name="boxCornerRadiusTopEnd">@dimen/radius_mobile_control</item>

        <item name="boxCornerRadiusBottomStart">@dimen/radius_mobile_control</item>

        <item name="boxCornerRadiusBottomEnd">@dimen/radius_mobile_control</item>

    </style>



    <style name="AppTheme.SearchField.EditText" parent="Widget.Material3.TextInputEditText.OutlinedBox">

        <item name="android:textColor">@color/textPrimary</item>

        <item name="android:textSize">14sp</item>

    </style>



    <style name="AppTheme.Switch" parent="Widget.Material3.CompoundButton.Switch">

        <!-- M3 uses thumbColor/trackColor (not thumbTint/trackTint) for CompoundButton drawable colors -->
        <item name="thumbColor">@color/switch_thumb_color</item>

        <item name="trackColor">@color/switch_track_color</item>

        <!-- Suppress M3 default checkmark decoration overlay (Fluent uses plain track fill) -->
        <item name="trackDecorationTint">@android:color/transparent</item>

    </style>



    <style name="AppTheme.BottomNavigation" parent="Widget.Material3.BottomNavigationView">

        <item name="itemIconTint">@color/bottom_nav_item_color</item>

        <item name="itemTextColor">@color/bottom_nav_item_color</item>

        <item name="android:background">@color/surface</item>

        <!-- M3: suppress active indicator pill for flat Fluent look -->
        <item name="itemActiveIndicatorStyle">@style/AppTheme.BottomNavigation.ActiveIndicator</item>

    </style>

    <style name="AppTheme.BottomNavigation.ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@android:color/transparent</item>
    </style>



    <style name="AppTheme.Button" parent="Widget.Material3.Button.TextButton" />

    <!--
        RecyclerView defaults. Built-in fast scroll stays off; [VerticalFastScrollHelper]
        draws a fixed-height thumb (see fastscroll_thumb_height) for long lists.
    -->
    <style name="AppTheme.FastScrollRecyclerView">
        <item name="android:scrollbars">none</item>
        <item name="android:clipToPadding">false</item>
        <item name="fastScrollEnabled">false</item>
    </style>

</resources>

