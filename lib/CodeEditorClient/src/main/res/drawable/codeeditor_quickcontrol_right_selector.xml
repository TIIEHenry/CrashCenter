<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android"
    android:enterFadeDuration="100"
    android:exitFadeDuration="120">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/cr_press_shape_fill" />
            <corners
                android:bottomRightRadius="@dimen/quick_control_btn_radius"
                android:topRightRadius="@dimen/quick_control_btn_radius" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/main_bottom_background_color" />
            <corners
                android:bottomRightRadius="@dimen/quick_control_btn_radius"
                android:topRightRadius="@dimen/quick_control_btn_radius" />
        </shape>
    </item>
</selector>
