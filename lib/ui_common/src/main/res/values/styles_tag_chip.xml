    <style name="Widget.CelestialRuler.TagChip.Filter.Overlay" parent="Widget.CelestialRuler.TagChip.Filter">
        <item name="android:textColor">@color/cr_tag_chip_overlay_text</item>
        <item name="chipBackgroundColor">@color/cr_tag_chip_overlay_background</item>
        <item name="chipStrokeColor">@color/cr_tag_chip_overlay_stroke_color</item>
        <item name="chipStrokeWidth">1dp</item>
    </style>
