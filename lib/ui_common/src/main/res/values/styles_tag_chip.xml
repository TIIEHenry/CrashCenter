    <style name="Widget.CelestialRuler.TagChip.Filter" parent="Widget.Material3.Chip.Filter">
        <item name="chipMinHeight">32dp</item>
        <item name="chipCornerRadius">14dp</item>
        <item name="chipStartPadding">12dp</item>
        <item name="chipEndPadding">12dp</item>
        <item name="checkedIconVisible">false</item>
